# ===== DeepSeek（阶段 0 先跑通这一家）=====
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# ===== OpenAI（预留，后续补齐）=====
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o

# ===== Gemini（预留，后续补齐）=====
GEMINI_API_KEY=
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
GEMINI_MODEL=gemini-2.0-flash

# ===== 默认使用哪个 provider =====
DEFAULT_PROVIDER=deepseek

# ===== 数据库 =====
DATABASE_URL=sqlite:///./jarvis_write.db

# ===== 请求默认参数 =====
DEFAULT_TEMPERATURE=0.7
DEFAULT_MAX_TOKENS=8192
DEFAULT_TIMEOUT=600

# ===== 多用户认证（阶段 8）=====
# 注册邀请码：固定共享码，只有填对才能注册；留空则关闭注册（任何人都不能注册）
INVITE_CODE=
# JWT 签名密钥：本地开发可用默认值；生产/公网部署必须改成随机长串，否则 token 可被伪造
JWT_SECRET=change-me-in-production-please-use-a-random-secret
# JWT 有效期（天）
JWT_EXPIRE_DAYS=30
# 初始管理员：首次启动/迁移时自动创建，存量无主数据归其名下。
# 密码默认值 admin12345 仅限本地开发；公网部署必须通过环境变量设强密码，
# 首次登录后请在设置页修改。
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin12345
