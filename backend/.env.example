# ===== DeepSeek（阶段 0 先跑通这一家）=====
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# ===== OpenAI（预留，后续补齐）=====
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o

# ===== Gemini（预留，后续补齐）=====
GEMINI_API_KEY=
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
GEMINI_MODEL=gemini-2.0-flash

# ===== 默认使用哪个 provider =====
DEFAULT_PROVIDER=deepseek

# ===== 数据库 =====
DATABASE_URL=sqlite:///./jarvis_write.db

# ===== 向量库 =====
CHROMA_PERSIST_DIR=./chroma_data

# ===== Embedding（语义记忆用，默认走默认 provider 的 /embeddings；
# 中转站不支持该接口时语义检索自动降级，不影响生成）=====
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_RETRIEVAL_K=4
# 专用 embedding 渠道（可选）：聊天渠道（如 DeepSeek 官方、部分中转站）没有
# /embeddings 接口时，在这里单独配一个便宜/免费的 embedding 渠道，语义记忆即可恢复。
# 推荐：硅基流动 bge-m3（免费，https://api.siliconflow.cn/v1，模型 BAAI/bge-m3）、
# 智谱 embedding-3、阿里 text-embedding-v3。
# 注意：设置页里保存的 per-user embedding 配置优先于这两项。
EMBEDDING_BASE_URL=
EMBEDDING_API_KEY=

# ===== 请求默认参数 =====
DEFAULT_TEMPERATURE=0.7
DEFAULT_MAX_TOKENS=8192
DEFAULT_TIMEOUT=600

# ===== 多用户认证（阶段 8）=====
# 注册邀请码：固定共享码，只有填对才能注册；留空则关闭注册（任何人都不能注册）
INVITE_CODE=
# JWT 签名密钥：本地开发可用默认值；生产/公网部署必须改成随机长串，否则 token 可被伪造
JWT_SECRET=change-me-in-production-please-use-a-random-secret
# JWT 有效期（天）
JWT_EXPIRE_DAYS=30
# 初始管理员：首次启动/迁移时自动创建，存量无主数据归其名下。
# 密码默认值 admin12345 仅限本地开发；公网部署必须通过环境变量设强密码，
# 首次登录后请在设置页修改。
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin12345
